// **************************************************************************
// JsonSerializableGenerator
// **************************************************************************

Reference<T> _$ReferenceFromJson<T>(Map json) =>
    $checkedCreate('Reference', json, ($checkedConvert) {
      $checkKeys(json, allowedKeys: const [r'$ref']);
      final val = Reference<T>(
        $ref: $checkedConvert(r'$ref', (v) => v as String),
      );
      return val;
    });

Map<String, dynamic> _$ReferenceToJson<T>(Reference<T> instance) =>
    <String, dynamic>{r'$ref': instance.$ref};
